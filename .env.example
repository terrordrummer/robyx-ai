# Robyx Configuration
# Copy this to .env and fill in your values, or run: python3 setup.py

# Required: Messaging platform — telegram, slack, or discord
ROBYX_PLATFORM=telegram

# Required: AI backend — claude, codex, or opencode
AI_BACKEND=claude

# Optional: Custom path to AI CLI binary (auto-detected if on PATH)
AI_CLI_PATH=

# Optional: Claude Code permission mode. Leave blank to use Claude's default
# safety prompts. Advanced users can set e.g. bypassPermissions explicitly.
CLAUDE_PERMISSION_MODE=

# Optional: Workspace root directory (default: ~/Workspace)
ROBYX_WORKSPACE=

# Optional: OpenAI API key for voice transcription
OPENAI_API_KEY=

# Optional: Unified scheduler tick interval in seconds (default: 60)
SCHEDULER_INTERVAL=60

# Optional: Auto-update check interval in seconds (default: 3600 = 1 hour)
UPDATE_CHECK_INTERVAL=3600

# Optional: reject reminders whose fire_at is older than this many seconds
# (default: 86400 = 24 h). Prevents a reminder that keeps hitting a transient
# delivery error from retrying forever.
REMINDER_MAX_AGE_SECONDS=86400

# Telegram compatibility keys.
# If ROBYX_PLATFORM=telegram, replace these with real Telegram values.
# If ROBYX_PLATFORM=slack or discord, leave the placeholder defaults in place.
ROBYX_BOT_TOKEN=unused-non-telegram-mode
ROBYX_CHAT_ID=0
ROBYX_OWNER_ID=0

# ── Slack (required if ROBYX_PLATFORM=slack) ──
# Bot token (xoxb-...)
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=
# Control room channel ID (e.g. C01234ABCDE)
SLACK_CHANNEL_ID=
# Your Slack user ID (e.g. U01234ABCDE)
SLACK_OWNER_ID=

# ── Discord (required if ROBYX_PLATFORM=discord) ──
# Bot token (from discord.com/developers > Applications > Bot)
DISCORD_BOT_TOKEN=
# Guild (server) ID — right-click server > Copy Server ID
DISCORD_GUILD_ID=
# Control room channel ID — right-click channel > Copy Channel ID
DISCORD_CONTROL_CHANNEL_ID=
# Your Discord user ID — Enable Developer Mode, right-click yourself > Copy User ID
DISCORD_OWNER_ID=

# ── Advanced / Legacy overrides (rarely needed) ──
# JSON overrides for model defaults and aliases. Prefer editing models.yaml instead.
# AI_MODEL_DEFAULTS={"orchestrator":"balanced","workspace":"balanced","specialist":"powerful","scheduled":"fast","one-shot":"fast"}
# AI_MODEL_ALIASES={"fast":{"claude":"haiku"},"balanced":{"claude":"sonnet"},"powerful":{"claude":"opus"}}
